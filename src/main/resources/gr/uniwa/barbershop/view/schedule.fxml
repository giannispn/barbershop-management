<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gr.uniwa.barbershop.controller.ScheduleController"
      spacing="12.0">
    <padding>
        <Insets top="4" right="4" bottom="4" left="4"/>
    </padding>

    <Label text="Ημερήσιο Πρόγραμμα"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <HBox spacing="8.0" alignment="CENTER_LEFT">
        <Label text="Ημέρα:"/>
        <DatePicker fx:id="scheduleDate"/>
        <Button text="Προβολή" onAction="#load"/>
        <Button text="Σήμερα" onAction="#today"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel" text="" style="-fx-text-fill: #64748b;"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTime"     text="Ώρα"        prefWidth="90"/>
            <TableColumn fx:id="colCustomer" text="Πελάτης"    prefWidth="190"/>
            <TableColumn fx:id="colEmployee" text="Εργαζόμενος" prefWidth="180"/>
            <TableColumn fx:id="colService"  text="Υπηρεσία"   prefWidth="170"/>
            <TableColumn fx:id="colStatus"   text="Κατάσταση"  prefWidth="130"/>
        </columns>
    </TableView>
</VBox>
