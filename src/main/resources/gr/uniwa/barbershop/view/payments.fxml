<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gr.uniwa.barbershop.controller.PaymentController"
      spacing="12.0">
    <padding>
        <Insets top="4" right="4" bottom="4" left="4"/>
    </padding>

    <Label text="Διαχείριση Πληρωμών"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Pick a customer to view/register payments -->
    <HBox spacing="8.0" alignment="CENTER_LEFT">
        <Label text="Πελάτης:"/>
        <ComboBox fx:id="customerCombo" prefWidth="260"/>
    </HBox>

    <Label text="Πληρωμές πελάτη" style="-fx-font-weight: bold;"/>
    <TableView fx:id="paymentTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDate"   text="Ημ/νία"   prefWidth="160"/>
            <TableColumn fx:id="colAmount" text="Ποσό (€)" prefWidth="120"/>
            <TableColumn fx:id="colMethod" text="Τρόπος"   prefWidth="120"/>
            <TableColumn fx:id="colAppt"   text="Ραντεβού" prefWidth="120"/>
        </columns>
    </TableView>

    <Separator/>

    <Label text="Νέα Πληρωμή" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

    <GridPane hgap="10.0" vgap="8.0">
        <columnConstraints>
            <ColumnConstraints minWidth="130"/>
            <ColumnConstraints minWidth="220" hgrow="SOMETIMES"/>
            <ColumnConstraints minWidth="100"/>
            <ColumnConstraints minWidth="160" hgrow="SOMETIMES"/>
        </columnConstraints>

        <Label text="Ραντεβού (προαιρ.)" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="appointmentCombo" maxWidth="Infinity"
                  GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Τρόπος *"          GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <ComboBox fx:id="methodCombo" maxWidth="Infinity"
                  GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Ποσό (€) *"         GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="amountField"    GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="8.0">
        <Button text="Καθαρισμός" onAction="#clearForm"/>
        <Button text="Καταχώρηση Πληρωμής" onAction="#registerPayment"
                style="-fx-base: #2980b9;"/>
    </HBox>
</VBox>
