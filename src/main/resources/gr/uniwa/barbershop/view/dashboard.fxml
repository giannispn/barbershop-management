<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gr.uniwa.barbershop.controller.DashboardController"
            prefWidth="980" prefHeight="640">

    <!-- Sidebar navigation -->
    <left>
        <VBox spacing="6.0" prefWidth="240" styleClass="sidebar">
            <padding>
                <Insets top="24" right="16" bottom="24" left="16"/>
            </padding>

            <Label text="Barbershop" styleClass="brand"/>
            <Label fx:id="welcomeLabel" text="" wrapText="true" styleClass="welcome"/>
            <Label fx:id="roleLabel" text="" styleClass="role-badge"/>

            <Region prefHeight="24"/>

            <Button text="Πελάτες" maxWidth="Infinity" onAction="#openCustomers" styleClass="nav-button"/>
            <Button text="Υπηρεσίες" maxWidth="Infinity" onAction="#openServices" styleClass="nav-button"/>
            <Button text="Ραντεβού" maxWidth="Infinity" onAction="#openAppointments" styleClass="nav-button"/>
            <Button text="Ημερήσιο Πρόγραμμα" maxWidth="Infinity" onAction="#openSchedule" styleClass="nav-button"/>
            <Button text="Πληρωμές" maxWidth="Infinity" onAction="#openPayments" styleClass="nav-button"/>

            <!-- Admin-only; hidden at runtime for non-admins -->
            <Button fx:id="employeesButton" text="Διαχείριση Εργαζομένων"
                    maxWidth="Infinity" onAction="#openEmployees" styleClass="nav-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Αποσύνδεση" maxWidth="Infinity"
                    onAction="#handleLogout" styleClass="logout-button"/>
        </VBox>
    </left>

    <!-- Content area; sub-views load here -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
            <Label fx:id="contentLabel"
                   text="Καλώς ήρθατε. Επιλέξτε μια λειτουργία από το μενού."
                   styleClass="placeholder"/>
        </StackPane>
    </center>
</BorderPane>
